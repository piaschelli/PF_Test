<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} — {% endif %}Pia Schelli</title>
  <meta name="description" content="UX Designer & Product Strategist — making complexity navigable.">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
</head>
<body>

<nav class="nav" id="nav">
  <a href="/" class="nav__logo">Pia Schelli</a>
  <ul class="nav__links">
    <li><a href="/work/" class="{% if page.url == '/work/' %}active{% endif %}">Work</a></li>
    <li><a href="/about/" class="{% if page.url == '/about/' %}active{% endif %}">About</a></li>
    <li><a href="mailto:p.schelli@gmx.de">Contact</a></li>
  </ul>
</nav>

<main>
  {{ content | safe }}
</main>

<footer class="footer">
  <div class="footer__inner">
    <span>© 2024 Pia Schelli</span>
    <div class="footer__links">
      <a href="mailto:p.schelli@gmx.de">Email</a>
      <a href="https://linkedin.com" target="_blank" rel="noopener">LinkedIn</a>
    </div>
  </div>
</footer>

<script>
  const nav = document.getElementById('nav');
  window.addEventListener('scroll', () => {
    nav.classList.toggle('scrolled', window.scrollY > 40);
  }, { passive: true });
</script>

</body>
</html>
