---
layout: base.njk
---

<article>

  <!-- Hero: two-column split -->
  <header class="cs-hero">
    <div class="cs-hero__left">
      <div class="cs-hero__meta">
        <span class="tag">{{ category }}</span>
        {% if year %}<span class="tag">{{ year }}</span>{% endif %}
      </div>
      <h1 class="cs-hero__title">{{ title }}</h1>
      {% if subtitle %}<p class="cs-hero__subtitle">{{ subtitle }}</p>{% endif %}
      <dl class="cs-meta-grid">
        {% if role %}<div><dt>Role</dt><dd>{{ role }}</dd></div>{% endif %}
        {% if organisation %}<div><dt>Organisation</dt><dd>{{ organisation }}</dd></div>{% endif %}
        {% if duration %}<div><dt>Duration</dt><dd>{{ duration }}</dd></div>{% endif %}
        {% if team %}<div class="cs-meta-grid__wide"><dt>Team</dt><dd>{{ team }}</dd></div>{% endif %}
        {% if methods %}<div class="cs-meta-grid__wide"><dt>Methods</dt><dd>{{ methods }}</dd></div>{% endif %}
      </dl>
    </div>
    <div class="cs-hero__right">
      {% if cover_image %}<img src="{{ cover_image }}" alt="{{ title }}">{% endif %}
    </div>
  </header>

  <!-- Stat highlight if defined -->
  {% if outcome_stat %}
  <div class="cs-stat">
    <span class="cs-stat__number">{{ outcome_stat }}</span>
    <p class="cs-stat__label">{{ outcome_label }}</p>
  </div>
  {% endif %}

  <!-- Main markdown body -->
  <div class="cs-content">
    {{ content | safe }}
  </div>

  <!-- Solution screens image grid if defined -->
  {% if solution_images and solution_images.length %}
  <div class="cs-image-grid cs-image-grid--screens">
    {% for img in solution_images %}
    <img src="{{ img }}" alt="{{ title }} screen {{ loop.index }}">
    {% endfor %}
  </div>
  {% endif %}

</article>

<nav class="cs-back">
  <a href="/work/">← All work</a>
</nav>
